#!/usr/bin/env python3
import os
import sys

script_dir = os.path.dirname(os.path.realpath(__file__))
repo_dir = os.path.abspath(os.path.join(script_dir, ".."))
install_dir = "/opt/pasar-eazylink"

if os.path.isdir(os.path.join(repo_dir, "pasar_eazylink")):
    sys.path.insert(0, repo_dir)
elif os.path.isdir(os.path.join(install_dir, "pasar_eazylink")):
    sys.path.insert(0, install_dir)

from pasar_eazylink.cli import main as easylink_main
from pasar_eazylink.sub_notify import main as monitor_db_main


def usage() -> int:
    print("Usage:")
    print("  pasar easylink")
    print("  pasar monitor-db [--test] [--send-test]")
    return 1


def main() -> int:
    if len(sys.argv) < 2:
        return usage()

    command = sys.argv[1].strip().lower()
    if command == "easylink":
        return int(easylink_main() or 0)
    if command in {"monitor-db", "subnotify-db", "sub-notify-db", "subnotify"}:
        return int(monitor_db_main(sys.argv[2:]) or 0)
    return usage()


if __name__ == "__main__":
    sys.exit(main())
